{
  "name": "@nodish/core",
  "private": false,
  "version": "0.2.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "style": "./dist/index.css"
    }
  },
  "scripts": {
    "setup:local": "node scripts/copy-dev-to-local.mjs",
    "dev": "node scripts/copy-dev-to-local.mjs && vite --config vite.config.dev.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:dev": "tsc --noEmit -p tsconfig.dev.json"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vue": "^3.5.39"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nodish/core.git"
  },
  "bugs": {
    "url": "https://github.com/nodish/core/issues"
  },
  "homepage": "https://github.com/nodish/core#readme",
  "publishConfig": {
    "access": "public"
  }
}
