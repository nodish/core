{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "lib": ["ES2023", "DOM"],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "paths": {
      "@nodish/core/pack": ["./src/pack/index.ts"],
      "@nodish/core/vue": ["./src/vue/index.ts"]
    }
  },
  "include": ["dev/**/*", "local/**/*", "src/vue-shims.d.ts"]
}
